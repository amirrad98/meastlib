FROM node:22-alpine AS build
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .
ARG VITE_SERVICE_URL=""
ENV VITE_SERVICE_URL=$VITE_SERVICE_URL
ENV VITE_PUBLIC_PORTAL=true
RUN npm run build

FROM nginx:alpine
COPY nginx.public.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html
