# Read-only host folder containing PDFs to discover from the Admin batch inbox.
MEASTLIB_INBOX_DIR=./data/inbox

# Keep two OCR workers on a typical laptop; increase only after observing memory use.
OCR_WORKERS=2

# "all" searches private local items; use "public" for an externally hosted portal.
MEASTLIB_SEARCH_VISIBILITY=all

# Optional catalog identification and Google Books fallback.
MEASTLIB_CATALOG_EMAIL=
GOOGLE_BOOKS_API_KEY=

# Public deployment reads only the output produced by pipeline/publish.py.
MEASTLIB_PUBLIC_DATA_DIR=./data/public
MEASTLIB_PUBLIC_PORT=8081
MEASTLIB_PUBLIC_SOLR_PORT=8984
